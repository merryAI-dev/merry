# AWS (server-side)
AWS_REGION=ap-northeast-2
MERRY_DDB_TABLE=merry-main
MERRY_S3_BUCKET=merry-private-apne2-seoul-471036546503
MERRY_SQS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/merry-analysis-jobs

# Workspace auth (simple team passcode)
WORKSPACE_JWT_SECRET=change-this-to-a-long-random-string
WORKSPACE_CODE=team-workspace-passcode

# Google OAuth (recommended)
# If GOOGLE_* is set, passcode login is disabled automatically.
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
NEXTAUTH_SECRET=change-this-to-a-long-random-string
# NEXTAUTH_URL=https://mysc-merry-inv.vercel.app
# Optional: enforce one canonical host in production (prevents cookie/session drift across many Vercel URLs)
# CANONICAL_HOST=mysc-merry-inv.vercel.app
AUTH_ALLOWED_DOMAIN=mysc.co.kr
AUTH_TEAM_ID=mysc

# Local dev shortcuts
# MERRY_AUTH_SKIP=true          # Skip workspace auth (local dev only, enforced by default)

# LLM (server-side)
LLM_PROVIDER=bedrock
# NOTE: Some Claude models require inference profiles (recommended). List with:
#   aws bedrock list-inference-profiles --region ap-northeast-2
# Use an inference profile ID/ARN for Anthropic models (many accounts can't use on-demand model IDs).
# Recommended (quality): global.anthropic.claude-sonnet-4-5-20250929-v1:0
# Cheaper: global.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
ANTHROPIC_API_KEY=sk-ant-... # optional fallback

# Optional: cost estimation overrides (USD per 1M tokens)
# If unset, defaults: Sonnet (6/30), Haiku (0.25/1.25), Opus (15/75)
LLM_INPUT_USD_PER_1M=
LLM_OUTPUT_USD_PER_1M=

# Fan-out job settings
# MERRY_MAX_CONCURRENT_FANOUT=3  # Max concurrent fan-out jobs per team

# Admin dashboard
# MERRY_ADMIN_TEAM_IDS=team1,team2  # Comma-separated team IDs with admin access

# CORS (comma-separated allowed origins, empty = same-origin only)
# MERRY_CORS_ORIGINS=https://example.com,https://app.example.com

# Rate limiting
# MERRY_RATE_LIMIT_MAX=60                  # Requests per minute per IP (0 = disabled)
# MERRY_RATE_LIMIT_WINDOW_MS=60000         # Sliding window in ms

# Upload presign
# MERRY_PRESIGN_EXPIRY_SECONDS=600         # S3 presigned URL TTL (10 min default)

# Airtable tuning
# MERRY_AIRTABLE_CACHE_TTL_MS=600000       # In-memory cache TTL (10 min)
# MERRY_AIRTABLE_TIMEOUT_MS=12000          # HTTP request timeout

# Airtable (server-side, funds UI)
# Prefer Airtable PAT (AIRTABLE_API_TOKEN). AIRTABLE_API_KEY is accepted as a fallback.
AIRTABLE_API_TOKEN=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_FUNDS_TABLE=Funds
AIRTABLE_FUNDS_VIEW=
AIRTABLE_SNAPSHOTS_TABLE=Fund Snapshots
AIRTABLE_SNAPSHOTS_VIEW=
AIRTABLE_SNAPSHOT_FUND_LINK_FIELD=Fund
AIRTABLE_SNAPSHOT_DATE_FIELD=Date
# AIRTABLE_DISABLE_SNAPSHOTS=1
