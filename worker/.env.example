# AWS
AWS_REGION=ap-northeast-2
MERRY_DDB_TABLE=merry-main
MERRY_S3_BUCKET=merry-private-apne2-seoul-471036546503
MERRY_SQS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/merry-analysis-jobs

# Security behavior
# Delete originals in uploads/ after processing (recommended)
MERRY_DELETE_INPUTS=true

# LLM (required for PDF 파싱 when using Bedrock-based Claude Vision)
LLM_PROVIDER=bedrock
# NOTE: Prefer inference profiles. List with:
#   aws bedrock list-inference-profiles --region ap-northeast-2
BEDROCK_MODEL_ID=apac.anthropic.claude-3-5-sonnet-20241022-v2:0
# Optional: cheaper model for simple text parsing in InteractiveAnalysisSession
# BEDROCK_HAIKU_MODEL_ID=apac.anthropic.claude-3-haiku-20240307-v1:0

# Concurrency & performance
# WORKER_CONCURRENCY=5             # Number of concurrent SQS message processors
# MERRY_DRAIN_TIMEOUT=120          # Seconds to wait for in-flight tasks on shutdown
# MERRY_HEALTH_PORT=8080           # Health check HTTP port

# VLM (Nova vision models for PDF quality assessment)
# RALPH_VLM_NOVA_MODEL_ID=us.amazon.nova-pro-v1:0
# RALPH_VLM_NOVA_LITE_MODEL_ID=us.amazon.nova-lite-v1:0
# RALPH_VLM_NOVA_REGION=us-east-1
# RALPH_USE_VLM=true               # Enable VLM fallback for low-quality PDFs

# Reliability
# MERRY_JOB_TIMEOUT_MINUTES=60     # Force-fail running jobs older than this (0=disable)
# MERRY_CB_ERROR_RATE=0.5          # Circuit breaker error rate threshold
# MERRY_CB_MIN_SAMPLES=5           # Circuit breaker minimum sample count
# MERRY_RESULT_CACHE=true          # Cache per-file results to skip reprocessing
# MERRY_CACHE_TTL_DAYS=7           # Cache TTL in days
# MERRY_BEDROCK_MAX_RETRIES=3      # Bedrock API call max retries
# MERRY_BEDROCK_RETRY_DELAY=1.5    # Bedrock retry base delay in seconds

# Observability
# MERRY_LOG_JSON=false             # Structured JSON logging (recommended for ECS)
# MERRY_CW_NAMESPACE=Merry/Worker  # CloudWatch metrics namespace
# MERRY_WEBHOOK_URL=               # Slack/webhook URL for job completion notifications
# MERRY_WEBHOOK_MAX_RETRIES=3      # Webhook delivery max retries

# Lambda assembly (Phase 2: DynamoDB Streams)
# MERRY_LAMBDA_ASSEMBLY=false      # Use Lambda for result assembly instead of worker
